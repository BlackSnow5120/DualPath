# DualPath — Supabase Configuration (Supabase Edition)

# Service Configuration
PORT=8080
GIN_MODE=debug

# Supabase PostgreSQL Configuration
# You can use the full connection string (recommended):
DATABASE_URL=postgres://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_ID].supabase.co:5432/postgres

# Or individual parameters:
# DB_HOST=db.[YOUR_PROJECT_ID].supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=[YOUR_PASSWORD]
# DB_NAME=postgres

# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...
